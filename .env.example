# Gemini API
# Get a key at https://aistudio.google.com/apikey then paste it below.
YTBRAIN_GEMINI_API_KEY=your-gemini-api-key
YTBRAIN_GEMINI_MODEL=gemini-3.5-flash
YTBRAIN_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
YTBRAIN_GEMINI_EMBEDDING_DIMENSIONS=768

# Storage
YTBRAIN_DATABASE_PATH=data/youtube_brain.db
