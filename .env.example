# YouTube Brain needs no API key. This file is OPTIONAL and only configures
# storage and transcript fetching. Copy to .env and uncomment what you need.

# Storage (defaults to data/youtube_brain.db)
# YTBRAIN_DATABASE_PATH=data/youtube_brain.db

# --- Optional: only for videos that rate-limit a direct transcript fetch ---

# scrape.do proxy token: routes transcript fetches through rotating residential
# IPs to bypass YouTube rate-limiting. Empty = direct fetch.
# YTBRAIN_SCRAPEDO_TOKEN=

# Read YouTube cookies from a browser for authenticated yt-dlp fetches, e.g.
# "firefox", "edge", "chrome", or "chrome:Profile 1". (Chrome >= 127 can't be
# read due to app-bound encryption; use Firefox or a cookies.txt instead.)
# YTBRAIN_YTDLP_COOKIES_BROWSER=

# Or point at a Netscape-format cookies.txt (takes precedence over the browser).
# YTBRAIN_YTDLP_COOKIES_FILE=
